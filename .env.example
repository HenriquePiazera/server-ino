# Supabase PostgreSQL — use Session pooler (IPv4). Copie do Dashboard → Connect.
# Formato: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres
# Se a senha tiver @ ou +, codifique na URL (@ → %40, + → %2B).
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# Auth.js / NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Criptografia (envelope encryption — KEK global)
# Gerar com: openssl rand -base64 32
ENCRYPTION_MASTER_KEY="generate-with-openssl-rand-base64-32"

# E-mail (Resend) — placeholder para V2
RESEND_API_KEY="re_placeholder_not_used_in_v1"

# Supabase Storage (Fase 7)
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Sentry
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
