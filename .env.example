# Supabase PostgreSQL — use Session pooler (IPv4). Copie do Dashboard → Connect.
# Formato: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres
# Se a senha tiver @ ou +, codifique na URL (@ → %40, + → %2B).
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# Auth.js / NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Criptografia (envelope encryption — KEK global)
# Gerar com: openssl rand -base64 32
ENCRYPTION_MASTER_KEY="generate-with-openssl-rand-base64-32"

# Modo cobrança — false libera todas as funcionalidades (sem CNPJ)
BILLING_ENABLED=false

# Push PWA — rode: npm run setup:notifications
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:seu@email.com"

# Cron de lembretes automáticos
CRON_SECRET="generate-with-openssl-rand-hex-32"

# E-mail (Resend) — https://resend.com/api-keys
# Teste: onboarding@resend.dev | Produção: domínio verificado
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"

# Supabase Storage (Fase 7)
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Donos da plataforma (painel /internal) — e-mails separados por vírgula
PLATFORM_OWNER_EMAILS=""

# Beta fechado — deixe vazio para cadastro aberto; ou liste e-mails permitidos
BETA_ALLOWED_EMAILS=""

# Sentry
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
